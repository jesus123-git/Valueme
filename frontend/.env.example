# ─── URL del backend ─────────────────────────────────────────────────────────
# En desarrollo: http://localhost:3001
# En producción: https://tu-backend.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3001

# Solo para Docker interno (Next.js SSR → backend)
INTERNAL_API_URL=http://backend:3001

# ─── Webhooks (debe coincidir con WEBHOOK_SECRET del backend) ─────────────────
NEXT_PUBLIC_WEBHOOK_SECRET=CAMBIA_ESTO_POR_UN_SECRET_SEGURO

# Google OAuth — mismo Client ID que el backend
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
