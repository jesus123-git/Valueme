DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finanzas
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── JWT ──────────────────────────────────────────────────────────────────────
# Genera un secreto seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_al_menos_32_chars
JWT_EXPIRES_IN=7d

# ── Webhooks ──────────────────────────────────────────────────────────────────
# Clave secreta que se envía en el header X-Nequi-Auth.
# Debe coincidir con NEXT_PUBLIC_NEQUI_WEBHOOK_SECRET en el frontend.
NEQUI_WEBHOOK_SECRET=cambia_esto_por_tu_clave_webhook_nequi
